{
  "name": "theta-cli-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local THETA CLI Agent built on Hypha tool governance contracts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "hypha:check": "node ../scripts/check-hypha-version.mjs",
    "hypha:build": "npm --prefix ../Hypha run build:packages",
    "smoke:hypha-import": "node dist/hypha-import-smoke.js",
    "smoke:hypha-registry": "node dist/hypha-registry-smoke.js",
    "smoke:hypha-runner": "node dist/hypha-runner-smoke.js",
    "smoke:hypha-model-recommend": "node dist/hypha-model-recommend-smoke.js"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "@hypha/core": "file:../Hypha/packages/core",
    "@hypha/tools": "file:../Hypha/packages/tools",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
